-- [SHOP TAB]
local PacketEvent = game:GetService("ReplicatedStorage"):WaitForChild("SharedModules"):WaitForChild("Packet"):WaitForChild("RemoteEvent")
local Lists = {
    Seed = {"Carrot", "Strawberry", "Blueberry", "Tulip", "Tomato", "Apple", "Bamboo", "Corn", "Cactus", "Pineapple", "Green Bean", "Banana", "Coconut", "Mango", "Grapes", "Acorn", "Horned Melon", "Baby Cactus", "Cherry", "Glow Mushroom", "Poison Ivy", "Sunflower", "Mushroom", "Moon Bloom", "Dragon's Breath"},
    Gear = {"Common Watering Can", "Super Watering Can", "Trowel", "Wheelbarrow", "Common Sprinkler", "Uncommon Sprinkler", "Rare Sprinkler", "Super Sprinkler", "Legendary Sprinkler", "Speed Mushroom", "Jump Mushroom", "Shrink Mushroom", "Invisibility Mushroom", "Flashbang", "Lantern", "Gnome", "Teleporter", "Basic Pot"},
    Crate = {"Ladder Crate", "Bench Crate", "Light Crate", "Sign Crate", "Arch Crate", "Roleplay Crate", "Bridge Crate", "Conveyor Crate", "Spring Crate", "Seesaw Crate", "Owner Door Crate", "Bear Trap Crate", "Fence Crate", "Teleporter Pad Crate"}
}

for name, list in pairs(Lists) do
    Tabs.Shop:AddSection(name)
    local Selected = {}
    local prefix = (name == "Seed" and "y") or (name == "Gear" and "}") or "{"
    Tabs.Shop:AddDropdown(name.."Selector", {Title = "Select "..name, Values = list, Multi = true, Default = {}, Callback = function(v) Selected = v end})
    Tabs.Shop:AddToggle("Buy"..name.."Toggle", {Title = "Auto Buy "..name, Callback = function(v)
        if v then threads["Buy"..name] = task.spawn(function() while v do for n, s in pairs(Selected) do if s then PacketEvent:FireServer(buffer.fromstring(prefix.."\x00"..string.char(#n)..n)) task.wait(0.1) end end task.wait(0.5) end end)
        else if threads["Buy"..name] then task.cancel(threads["Buy"..name]) end end
    end})
end

