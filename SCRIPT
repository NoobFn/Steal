-- [THREAD MANAGEMENT]
local threads = {}
local function manageLoadstring(name, url, enabled)
    if enabled then
        threads[name] = task.spawn(function() loadstring(game:HttpGet(url))() end)
    else
        if threads[name] then task.cancel(threads[name]); threads[name] = nil end
    end
end

